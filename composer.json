{
    "name": "psc-acme/exporter-product",
    "description": "Package exporter-product for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ExporterProduct\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/symfony": "^6.3",
        "doctrine/orm": "^3.0"
    },
    "require-dev": {
        "behat/behat": "^3.14"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}